{
  "title": "Claude Cowork Monitoring",
  "tags": ["claude", "cowork", "opentelemetry"],
  "timezone": "browser",
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Total API Requests",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "loki", "uid": "${logsDs}" },
      "targets": [{
        "expr": "sum(count_over_time({service_name=\"cowork\"} | event_name=`api_request` [$__auto]))",
        "refId": "A"
      }],
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value", "reduceOptions": { "calcs": ["sum"] } },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } }
      }
    },
    {
      "type": "stat",
      "title": "Total Cost (USD)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "loki", "uid": "${logsDs}" },
      "targets": [{
        "expr": "sum(sum_over_time({service_name=\"cowork\"} | event_name=`api_request` | unwrap cost_usd [$__auto]))",
        "refId": "A"
      }],
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value", "reduceOptions": { "calcs": ["sum"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 10 }, { "color": "red", "value": 50 }] }
        }
      }
    },
    {
      "type": "stat",
      "title": "Total Prompts",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "loki", "uid": "${logsDs}" },
      "targets": [{
        "expr": "sum(count_over_time({service_name=\"cowork\"} | event_name=`user_prompt` [$__auto]))",
        "refId": "A"
      }],
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value", "reduceOptions": { "calcs": ["sum"] } },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "purple", "value": null }] } }
      }
    },
    {
      "type": "stat",
      "title": "Error Count",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "loki", "uid": "${logsDs}" },
      "targets": [{
        "expr": "sum(count_over_time({service_name=\"cowork\"} | event_name=`api_error` [$__auto]))",
        "refId": "A"
      }],
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value", "reduceOptions": { "calcs": ["sum"] } },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }
      }
    },
    {
      "type": "row",
      "title": "User Activity",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "API Requests by User",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "loki", "uid": "${logsDs}" },
      "targets": [{
        "expr": "sum by (user_email) (count_over_time({service_name=\"cowork\"} | event_name=`api_request` [$__auto]))",
        "legendFormat": "{{user_email}}",
        "refId": "A"
      }],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } } }
    },
    {
      "type": "timeseries",
      "title": "Cost by User",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "loki", "uid": "${logsDs}" },
      "targets": [{
        "expr": "sum by (user_email) (sum_over_time({service_name=\"cowork\"} | event_name=`api_request` | unwrap cost_usd [$__auto]))",
        "legendFormat": "{{user_email}}",
        "refId": "A"
      }],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4, "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } } }
    },
    {
      "type": "row",
      "title": "Cost & Tokens",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "type": "piechart",
      "title": "Cost by Model",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "datasource": { "type": "loki", "uid": "${logsDs}" },
      "targets": [{
        "expr": "sum by (model) (sum_over_time({service_name=\"cowork\"} | event_name=`api_request` | unwrap cost_usd [$__auto]))",
        "legendFormat": "{{model}}",
        "refId": "A"
      }],
      "options": { "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] } }
    },
    {
      "type": "timeseries",
      "title": "Token Usage",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 15 },
      "datasource": { "type": "loki", "uid": "${logsDs}" },
      "targets": [
        {
          "expr": "sum(sum_over_time({service_name=\"cowork\"} | event_name=`api_request` | unwrap input_tokens [$__auto]))",
          "legendFormat": "Input Tokens",
          "refId": "A"
        },
        {
          "expr": "sum(sum_over_time({service_name=\"cowork\"} | event_name=`api_request` | unwrap output_tokens [$__auto]))",
          "legendFormat": "Output Tokens",
          "refId": "B"
        },
        {
          "expr": "sum(sum_over_time({service_name=\"cowork\"} | event_name=`api_request` | unwrap cache_read_tokens [$__auto]))",
          "legendFormat": "Cache Read",
          "refId": "C"
        }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } } }
    },
    {
      "type": "piechart",
      "title": "Speed Mode (Fast / Normal)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 23 },
      "datasource": { "type": "loki", "uid": "${logsDs}" },
      "targets": [{
        "expr": "sum by (speed) (count_over_time({service_name=\"cowork\"} | event_name=`api_request` [$__auto]))",
        "legendFormat": "{{speed}}",
        "refId": "A"
      }],
      "options": { "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] } }
    },
    {
      "type": "timeseries",
      "title": "API Response Duration",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 23 },
      "datasource": { "type": "loki", "uid": "${logsDs}" },
      "targets": [
        {
          "expr": "avg(avg_over_time({service_name=\"cowork\"} | event_name=`api_request` | unwrap duration_ms [$__auto]))",
          "legendFormat": "Avg",
          "refId": "A"
        },
        {
          "expr": "max(max_over_time({service_name=\"cowork\"} | event_name=`api_request` | unwrap duration_ms [$__auto]))",
          "legendFormat": "Max",
          "refId": "B"
        }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "fillOpacity": 5 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Avg" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Max" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "type": "row",
      "title": "Tool Usage",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "collapsed": false
    },
    {
      "type": "barchart",
      "title": "Top Tools by Usage",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "loki", "uid": "${logsDs}" },
      "targets": [{
        "expr": "topk(15, sum by (tool_name) (count_over_time({service_name=\"cowork\"} | event_name=`tool_result` [$__auto])))",
        "legendFormat": "{{tool_name}}",
        "refId": "A",
        "instant": true
      }],
      "options": { "orientation": "horizontal" }
    },
    {
      "type": "timeseries",
      "title": "Tool Decisions (Accept / Reject)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "loki", "uid": "${logsDs}" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"cowork\"} | event_name=`tool_decision` | decision=`accept` [$__auto]))",
          "legendFormat": "Accept",
          "refId": "A"
        },
        {
          "expr": "sum(count_over_time({service_name=\"cowork\"} | event_name=`tool_decision` | decision=`reject` [$__auto]))",
          "legendFormat": "Reject",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "Accept" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Reject" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "type": "row",
      "title": "Errors",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "API Errors Over Time",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 41 },
      "datasource": { "type": "loki", "uid": "${logsDs}" },
      "targets": [{
        "expr": "sum(count_over_time({service_name=\"cowork\"} | event_name=`api_error` [$__auto]))",
        "legendFormat": "Errors",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "color": { "fixedColor": "red", "mode": "fixed" }, "custom": { "fillOpacity": 30 } } }
    },
    {
      "type": "logs",
      "title": "Recent Errors",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 41 },
      "datasource": { "type": "loki", "uid": "${logsDs}" },
      "targets": [{
        "expr": "{service_name=\"cowork\"} | event_name=`api_error`",
        "refId": "A"
      }],
      "options": { "showTime": true, "showLabels": false, "showCommonLabels": false, "wrapLogMessage": true, "enableLogDetails": true, "sortOrder": "Descending" }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "logsDs",
        "type": "datasource",
        "query": "loki",
        "current": {},
        "hide": 0,
        "label": "Logs Data Source"
      }
    ]
  },
  "schemaVersion": 39
}
