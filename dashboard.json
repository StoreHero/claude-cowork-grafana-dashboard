{
  "title": "Claude Cowork Monitoring",
  "tags": [
    "claude",
    "cowork",
    "opentelemetry"
  ],
  "timezone": "browser",
  "refresh": "1m",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Total API Requests",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "loki",
        "uid": "${logsDs}"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"cowork\"} | event_name=`api_request` [$__auto]))",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Total Cost (USD)",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "datasource": {
        "type": "loki",
        "uid": "${logsDs}"
      },
      "targets": [
        {
          "expr": "sum(sum_over_time({service_name=\"cowork\"} | event_name=`api_request` | unwrap cost_usd [$__auto]))",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 10
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Total Prompts",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "type": "loki",
        "uid": "${logsDs}"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"cowork\"} | event_name=`user_prompt` [$__auto]))",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "purple",
                "value": null
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Error Count",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "datasource": {
        "type": "loki",
        "uid": "${logsDs}"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"cowork\"} | event_name=`api_error` [$__auto]))",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "type": "row",
      "title": "User Activity",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "API Requests by User",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "loki",
        "uid": "${logsDs}"
      },
      "targets": [
        {
          "expr": "sum by (user_email) (count_over_time({service_name=\"cowork\"} | event_name=`api_request` [1d]))",
          "legendFormat": "{{user_email}}",
          "refId": "A",
          "step": "1d"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "stacking": {
              "mode": "none"
            },
            "drawStyle": "line"
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Cost by User",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "datasource": {
        "type": "loki",
        "uid": "${logsDs}"
      },
      "targets": [
        {
          "expr": "sum by (user_email) (sum_over_time({service_name=\"cowork\"} | event_name=`api_request` | unwrap cost_usd [1d]))",
          "legendFormat": "{{user_email}}",
          "refId": "A",
          "step": "1d"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "custom": {
            "fillOpacity": 10,
            "stacking": {
              "mode": "none"
            },
            "drawStyle": "line"
          }
        }
      }
    },
    {
      "type": "table",
      "title": "User Summary",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "datasource": {
        "type": "loki",
        "uid": "${logsDs}"
      },
      "targets": [
        {
          "expr": "sum by (user_email) (count_over_time({service_name=\"cowork\"} | event_name=`api_request` [$__auto]))",
          "legendFormat": "{{user_email}}",
          "refId": "A",
          "instant": true
        },
        {
          "expr": "sum by (user_email) (sum_over_time({service_name=\"cowork\"} | event_name=`api_request` | unwrap cost_usd [$__auto]))",
          "legendFormat": "{{user_email}}",
          "refId": "B",
          "instant": true
        },
        {
          "expr": "sum by (user_email) (count_over_time({service_name=\"cowork\"} | event_name=`user_prompt` [$__auto]))",
          "legendFormat": "{{user_email}}",
          "refId": "C",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "user_email": "User",
              "Value #A": "API Requests",
              "Value #B": "Cost (USD)",
              "Value #C": "Prompts"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "sort": [
              {
                "field": "Cost (USD)",
                "desc": true
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Cost (USD)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              },
              {
                "id": "decimals",
                "value": 2
              }
            ]
          }
        ]
      }
    },
    {
      "type": "row",
      "title": "AI Utilization — AI利活用の絶対量",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "1-1: Sessions by User",
      "description": "ユーザー別セッション数の推移（session_idのユニーク数）",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 23
      },
      "datasource": {
        "type": "loki",
        "uid": "${logsDs}"
      },
      "targets": [
        {
          "expr": "count without (session_id) (sum by (session_id, user_email) (count_over_time({service_name=\"cowork\"} | event_name=`user_prompt` [1d])))",
          "legendFormat": "{{user_email}}",
          "refId": "A",
          "step": "1d"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "stacking": {
              "mode": "none"
            }
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "1-2: Prompts by User",
      "description": "ユーザー別プロンプト送信数の推移",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 23
      },
      "datasource": {
        "type": "loki",
        "uid": "${logsDs}"
      },
      "targets": [
        {
          "expr": "sum by (user_email) (count_over_time({service_name=\"cowork\"} | event_name=`user_prompt` [1d]))",
          "legendFormat": "{{user_email}}",
          "refId": "A",
          "step": "1d"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "stacking": {
              "mode": "none"
            }
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "1-6: Avg Prompts per Session",
      "description": "ユーザー別セッション当たり平均プロンプト数（利用深度の指標）",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 31
      },
      "datasource": {
        "type": "loki",
        "uid": "${logsDs}"
      },
      "targets": [
        {
          "expr": "avg without (session_id) (sum by (session_id, user_email) (count_over_time({service_name=\"cowork\"} | event_name=`user_prompt` [1d])))",
          "legendFormat": "{{user_email}}",
          "refId": "A",
          "step": "1d"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "2-4: Sub-agent (Task) Usage by User",
      "description": "ユーザー別サブエージェント利用回数の推移（tool_name=Task）",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 31
      },
      "datasource": {
        "type": "loki",
        "uid": "${logsDs}"
      },
      "targets": [
        {
          "expr": "sum by (user_email) (count_over_time({service_name=\"cowork\"} | event_name=`tool_result` | tool_name=`Task` [1d]))",
          "legendFormat": "{{user_email}}",
          "refId": "A",
          "step": "1d"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "stacking": {
              "mode": "none"
            }
          }
        }
      }
    },
    {
      "type": "barchart",
      "title": "1-4: Skill Usage Ranking",
      "description": "Skill名別の利用回数ランキング（tool_parametersからskill_nameを抽出）",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 39
      },
      "datasource": {
        "type": "loki",
        "uid": "${logsDs}"
      },
      "targets": [
        {
          "expr": "sort_desc(topk(15, sum by (skill_name) (count_over_time({service_name=\"cowork\"} | event_name=`tool_result` | tool_name=`Skill` | line_format `{{.tool_parameters}}` | json | __error__=`` [$__auto]))))",
          "legendFormat": "{{skill_name}}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "orientation": "horizontal"
      }
    },
    {
      "type": "barchart",
      "title": "1-5: MCP Tool Usage Ranking",
      "description": "MCPツール名別の利用回数ランキング（tool_parametersからmcp_tool_nameを抽出）",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 39
      },
      "datasource": {
        "type": "loki",
        "uid": "${logsDs}"
      },
      "targets": [
        {
          "expr": "sort_desc(topk(15, sum by (mcp_tool_name) (count_over_time({service_name=\"cowork\"} | event_name=`tool_result` | tool_name=`mcp_tool` | line_format `{{.tool_parameters}}` | json | __error__=`` [$__auto]))))",
          "legendFormat": "{{mcp_tool_name}}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "orientation": "horizontal"
      }
    },
    {
      "type": "row",
      "title": "Best Practices — ベストプラクティス遵守",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 47
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "2-2: Personal Skill Usage by User",
      "description": "個人作成スキル（gp-toolkit以外）のユーザー別利用推移",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 48
      },
      "datasource": {
        "type": "loki",
        "uid": "${logsDs}"
      },
      "targets": [
        {
          "expr": "sum by (user_email) (count_over_time({service_name=\"cowork\"} | event_name=`tool_result` | tool_name=`Skill` | line_format `{{.tool_parameters}}` | json | skill_name!~`gp-toolkit:.*` | __error__=`` [1d]))",
          "legendFormat": "{{user_email}}",
          "refId": "A",
          "step": "1d"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "stacking": {
              "mode": "none"
            }
          }
        }
      }
    },
    {
      "type": "barchart",
      "title": "2-3: Provided Skill (gp-toolkit) Usage",
      "description": "提供スキル（gp-toolkit:*）のSkill別利用回数",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 48
      },
      "datasource": {
        "type": "loki",
        "uid": "${logsDs}"
      },
      "targets": [
        {
          "expr": "sort_desc(topk(15, sum by (skill_name) (count_over_time({service_name=\"cowork\"} | event_name=`tool_result` | tool_name=`Skill` | line_format `{{.tool_parameters}}` | json | skill_name=~`gp-toolkit:.*` | __error__=`` [$__auto]))))",
          "legendFormat": "{{skill_name}}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "orientation": "horizontal"
      }
    },
    {
      "type": "timeseries",
      "title": "2-1: Max Prompts per Session",
      "description": "ユーザー別セッション当たり最大プロンプト数（セッション分割の適切さ判定。値が大きいユーザーは1セッションに詰め込みすぎの可能性）",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 56
      },
      "datasource": {
        "type": "loki",
        "uid": "${logsDs}"
      },
      "targets": [
        {
          "expr": "max without (session_id) (sum by (session_id, user_email) (count_over_time({service_name=\"cowork\"} | event_name=`user_prompt` [1d])))",
          "legendFormat": "{{user_email}} (max)",
          "refId": "A",
          "step": "1d"
        },
        {
          "expr": "avg without (session_id) (sum by (session_id, user_email) (count_over_time({service_name=\"cowork\"} | event_name=`user_prompt` [1d])))",
          "legendFormat": "{{user_email}} (avg)",
          "refId": "B",
          "step": "1d"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 5
          }
        }
      }
    },
    {
      "type": "row",
      "title": "Cost & Tokens",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 64
      },
      "collapsed": false
    },
    {
      "type": "piechart",
      "title": "Cost by Model",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 65
      },
      "datasource": {
        "type": "loki",
        "uid": "${logsDs}"
      },
      "targets": [
        {
          "expr": "sum by (model) (sum_over_time({service_name=\"cowork\"} | event_name=`api_request` | unwrap cost_usd [$__auto]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Token Usage",
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 8,
        "y": 65
      },
      "datasource": {
        "type": "loki",
        "uid": "${logsDs}"
      },
      "targets": [
        {
          "expr": "sum(sum_over_time({service_name=\"cowork\"} | event_name=`api_request` | unwrap input_tokens [1d]))",
          "legendFormat": "Input Tokens",
          "refId": "A",
          "step": "1d"
        },
        {
          "expr": "sum(sum_over_time({service_name=\"cowork\"} | event_name=`api_request` | unwrap output_tokens [1d]))",
          "legendFormat": "Output Tokens",
          "refId": "B",
          "step": "1d"
        },
        {
          "expr": "sum(sum_over_time({service_name=\"cowork\"} | event_name=`api_request` | unwrap cache_read_tokens [1d]))",
          "legendFormat": "Cache Read",
          "refId": "C",
          "step": "1d"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "type": "piechart",
      "title": "Speed Mode (Fast / Normal)",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 73
      },
      "datasource": {
        "type": "loki",
        "uid": "${logsDs}"
      },
      "targets": [
        {
          "expr": "sum by (speed) (count_over_time({service_name=\"cowork\"} | event_name=`api_request` [$__auto]))",
          "legendFormat": "{{speed}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        }
      }
    },
    {
      "type": "timeseries",
      "title": "API Response Duration",
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 8,
        "y": 73
      },
      "datasource": {
        "type": "loki",
        "uid": "${logsDs}"
      },
      "targets": [
        {
          "expr": "avg(avg_over_time({service_name=\"cowork\"} | event_name=`api_request` | unwrap duration_ms [1d]))",
          "legendFormat": "Avg",
          "refId": "A",
          "step": "1d"
        },
        {
          "expr": "max(max_over_time({service_name=\"cowork\"} | event_name=`api_request` | unwrap duration_ms [1d]))",
          "legendFormat": "Max",
          "refId": "B",
          "step": "1d"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "fillOpacity": 5
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Avg"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Max"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "row",
      "title": "Tool Usage",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 81
      },
      "collapsed": false
    },
    {
      "type": "barchart",
      "title": "Top Tools by Usage",
      "gridPos": {
        "h": 8,
        "w": 12,
